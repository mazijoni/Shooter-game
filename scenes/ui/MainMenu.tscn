[gd_scene load_steps=3 format=3]

[ext_resource type="Script" path="res://src/ui/MainMenu.gd" id="1_mainmenu"]
[ext_resource type="PackedScene" path="res://scenes/ui/Settings.tscn" id="2_settings"]

[node name="MainMenu" type="Control"]
layout_mode = 1
anchor_right = 1.0
anchor_bottom = 1.0
script = ExtResource("1_mainmenu")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0.05, 0.05, 0.07, 1)

[node name="MenuPanel" type="Control" parent="."]
layout_mode = 1
anchor_right = 1.0
anchor_bottom = 1.0

[node name="Center" type="CenterContainer" parent="MenuPanel"]
layout_mode = 1
anchor_right = 1.0
anchor_bottom = 1.0

[node name="VBox" type="VBoxContainer" parent="MenuPanel/Center"]
layout_mode = 2
custom_minimum_size = Vector2(320, 0)
theme_override_constants/separation = 16

[node name="Title" type="Label" parent="MenuPanel/Center/VBox"]
layout_mode = 2
text = "HORROR FAST SHOOTER"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 36

[node name="Spacer" type="Control" parent="MenuPanel/Center/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(0, 24)

[node name="PlayButton" type="Button" parent="MenuPanel/Center/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(0, 50)
text = "PLAY"
theme_override_font_sizes/font_size = 18

[node name="SettingsButton" type="Button" parent="MenuPanel/Center/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(0, 50)
text = "SETTINGS"
theme_override_font_sizes/font_size = 18

[node name="QuitButton" type="Button" parent="MenuPanel/Center/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(0, 50)
text = "QUIT"
theme_override_font_sizes/font_size = 18

[node name="SettingsPanel" parent="." instance=ExtResource("2_settings")]
visible = false

[connection signal="pressed" from="MenuPanel/Center/VBox/PlayButton" to="." method="_on_play_pressed"]
[connection signal="pressed" from="MenuPanel/Center/VBox/SettingsButton" to="." method="_on_settings_pressed"]
[connection signal="pressed" from="MenuPanel/Center/VBox/QuitButton" to="." method="_on_quit_pressed"]
[connection signal="back_pressed" from="SettingsPanel" to="." method="_on_settings_back"]
